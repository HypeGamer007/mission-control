# Supabase — Mission Control uses ONLY these two in the browser + server helpers.
# Use your Mission Control project: Project Settings → API → Project URL + anon public key.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_PUBLIC_KEY"

# If you use server-side Supabase (optional in this starter)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# OpenClaw Gateway (browser connects directly)
# Default local Gateway is usually root (no path): ws://127.0.0.1:18789
# Some deployments proxy the WS under a path like /ws.
NEXT_PUBLIC_OPENCLAW_GATEWAY_WS_URL="ws://127.0.0.1:18789"

# Optional: prefill token for local dev (do not use in production)
NEXT_PUBLIC_OPENCLAW_OPERATOR_TOKEN=""

