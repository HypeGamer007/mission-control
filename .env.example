# =============================================================================
# MOCK TEMPLATE ONLY — copy to ".env.local" and replace every MOCK value.
# ".env.local" is gitignored; never commit real URLs, keys, or tokens.
# =============================================================================

# --- Supabase (Dashboard → Project Settings → API) ---
# Project URL looks like: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxx.supabase.co"

# "anon" / "public" key (safe for browser with RLS; still keep out of public repos if you fork)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.MOCK_REPLACE_WITH_REAL_ANON_KEY_FROM_SUPABASE"

# Optional: service role for trusted server-only scripts (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.MOCK_REPLACE_WITH_SERVICE_ROLE_IF_NEEDED"

# --- OpenClaw Gateway (browser connects directly over WebSocket) ---
# Local default is often root path, e.g. ws://127.0.0.1:18789
# Behind TLS or a proxy you might use wss://host/app/ws
NEXT_PUBLIC_OPENCLAW_GATEWAY_WS_URL="ws://127.0.0.1:18789"

# Operator token for Gateway auth (scopes operator.read / operator.write in app)
# Leave empty only if your Gateway allows unauthenticated operator in dev (not recommended)
NEXT_PUBLIC_OPENCLAW_OPERATOR_TOKEN="oc_op_mock_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
